{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/license-error/layout,_N_T_/license-error/page,_N_T_/license-error"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/license-error/__PAGE__",
    "/license-error",
    "/_index",
    "/_head"
  ]
}